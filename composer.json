{
    "name": "frankyframework/franky-skeleton-application",
    "description": "Skeleton Application for Franky Framework applications",
    "type": "project",
    "version": "1.0.0",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^7.0",
        "phpmailer/phpmailer": "~6.0",
        "mobiledetect/mobiledetectlib": "^2.8",
        "izica/php-progressive-images-webp-jp2-jxr": "^1.2",
        "shuchkin/simplexls": "^0.9.6",
        "frankyframework/franky-core": "1.0.x-dev",
        "frankyframework/franky-form": "1.0.x-dev",
        "frankyframework/franky-database": "1.0.x-dev",
        "frankyframework/franky-haxor": "1.0.x-dev",
        "frankyframework/franky-filesystem": "1.0.x-dev",
        "frankyframework/franky-schema": "1.0.x-dev",
        "frankyframework/base":"1.0.x-dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^6.5"
    },
    "autoload": {
            "psr-4": {
                "Franky\\": "modulos/franky/src"
            }
    }   

}